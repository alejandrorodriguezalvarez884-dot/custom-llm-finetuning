# =============================================================
# Anthropic API — used for image processing (required if PDFs
# contain images) and Q&A dataset generation (optional).
# If not set, images are skipped and chunks mode is used.
# =============================================================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# =============================================================
# Fine-tuning hyperparameters
# =============================================================
FINETUNE_EPOCHS=3
FINETUNE_BATCH_SIZE=2
FINETUNE_LORA_RANK=16
FINETUNE_MAX_SEQ_LEN=512
FINETUNE_LEARNING_RATE=2e-4

# =============================================================
# Inference server
# =============================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
